          { "type": "canticle", "ref": "Daniel 3:57-88, 56", "antiphon_key": "w1-sun-lauds-cant", "default_antiphon": "Галын дөлийн дундаас гурван залуу эр нэгэн дуугаар ийн хашхирав: \"Тэнгэрбурхан магтагдах болтугай\". Аллэлуяа!", "title": "Эзэний хамаг бүтээлүүд ээ, Эзэнийг магтагтун", "gloria_patri": false },
