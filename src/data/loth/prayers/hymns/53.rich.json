  "hymnRich": {
    "blocks": [
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэн жаал Хүү маань хонох байр олдоогүй"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "тул"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эрх чадалт дээд Хүмүүн малын тэвшинд хэвтсэн"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Энх тэнгэрийн түмэн одод гялалзаж байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Энхрий бяцхан Есүс малын тэвшинд хэвтсэн"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Малын дуу жаал Хүүг маань цочоон сэрээсэн ч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Мөнхийн даруу Есүс огтхон ч уйлсангүй"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Сүр хүчит Их Эзэнийг би хайрлаж байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Шинэ өдрийн үүр цайтал хамтдаа байцгаая"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэн Есүс Эзэн надтай ойрхон байж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Элбэрэлт хосгүй хайраа үргэж харуулдаг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Энэ дэлхийн хүн бүхэн Есүс Хүүг хамгаалж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний ивээл дор мөнхөд амьдарцгаая"
              }
            ],
            "indent": 0
          }
        ]
      }
    ],
