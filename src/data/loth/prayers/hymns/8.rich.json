          {
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч Эзэн Есүстэйгээ нэгдэцгээж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Түүний ивээлийг хуваалцъя"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ариун Сүнсний хайраар бүгдээрээ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бие биенийгээ хайрлацгаая"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дахилт: Ертөнцийн Эзэний сургаалаар"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Өөрийн бие шигээ нэгнээ хайрлацгаая"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Үзэн ядалт атаа хорслоо орхиод"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хэн хэнийгээ хайрлацгаая"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч Эзэн Есүс дэлхий дээр ирэхэд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бид нар Түүнтэй яаж ярих вэ?"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Тэгэхэд бид нар ичих юмгүй бүгдээрээ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бие биенийгээ хайрлацгаая"
              }
            ],
            "indent": 0
          }
        ]
