            "spans": [
              {
                "kind": "text",
                "text": "1.Бүх дэлхий Эзэнд шинэ дуугаа дуулагтун"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эзэнд дуулж Түүний нэрийг магтагтун"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "2.Тэнгэрүүдийг баясгаж газар дэлхийг баярлуул"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Далай болон талбай бүх юмсыг баясга"
              }
            ],
            "indent": 0
          }
        ]
      },
