        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "3.Тэрээр газар дэлхийг шүүхээр ирж байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Тэрээр ертөнцийг шудрагаар шүүнэ"
