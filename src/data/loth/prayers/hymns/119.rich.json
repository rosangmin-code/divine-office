        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "1. Тээнэгэлзэх зүйл надад үгүй"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Түүний мөнхийн агуу их хайр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Миний сэтгэлд гүн шингэжээ"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дахилт:"
