            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "3. Бүхний Хаан Эзэн"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бүгдийг уучилах агуу сэтгэлтэй"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бид бүгд гэмээ гэмшин наминчилж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бахархалтайгаар Эзэнээ угтацгаая"
              }
            ],
            "indent": 0
          }
