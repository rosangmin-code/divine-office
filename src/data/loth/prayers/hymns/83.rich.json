  "hymnRich": {
    "blocks": [
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хөх тэнгэрийн агуу Их Эзэн минь"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Монгол түмний минь сэтгэлийг Та анагаагаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Уянгат сайхан аялгуу шингэсэн"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Зүрх сэтгэл амь амьдралаа Тандаа зориулъя"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эцэг дээдэс минь нэгэн цагт"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн тэнгэр минь гэж дууддаг байсан"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эрин зууны үр удам нь болсон бид"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ирээдүйгээ Эзэн тэнгэр минь гэж эхэлнэ"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дахилт: Та адислаач миний Монголыг"
              }
            ],
            "indent": 0
          }
        ]
      }
