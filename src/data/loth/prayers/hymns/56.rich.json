            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний хүртээсэн давалгаа мэт агуу хайр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Энэ бяцхан цээжинд минь давалгаалан бялхаж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэнийхээ тэр хайрыг бодон бодсоор залбирах"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "үед"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Нүдэнд хурсан нулимас минь садран асгаран"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "урсаж байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний агуу хайр төгсгөлгүй хязгааргүй"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Сэтгэл зүрх сүнсэнд минь туяаран гийх гэрэл юм"
              }
            ],
            "indent": 0
          }
        ]
      }
