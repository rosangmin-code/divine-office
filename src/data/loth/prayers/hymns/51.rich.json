  "hymnRich": {
    "blocks": [
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ирээч Ариун Сүнс ээ над дээр буугаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Намайг тослооч өөрийн xүч чадлаараа"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Сүнсийг минь xооллогч ариун сүнсэнд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "би xайртай"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Өдөр бүр Таны xайранд өсдөг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Зүрxэнд тань xүрэх юмсан"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Амьдралыг минь атгаач Та"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Надтай улам ойр байгаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хүч чадлыг тань мэдрэхсэн"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Юутай ч зүйрлэшгүй оршихуйд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Таньтайгаа учран уулзахсан"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Сүнсээр ба үнэнээр xүндэлье Tаныг"
              }
            ],
            "indent": 0
          }
        ]
      }
    ],
