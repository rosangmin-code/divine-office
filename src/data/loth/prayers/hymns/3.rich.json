            "spans": [
              {
                "kind": "text",
                "text": "Махбод дотор нь үзэгднэм"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэр нялхыг манцуйлсан буй."
