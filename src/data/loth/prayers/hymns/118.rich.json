              {
                "kind": "text",
                "text": "Их Эзэн үгээ айлдвал"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "би даган явъя"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний хүсэл биш бол"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "би зогсон хүлээе"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Миний бүхий л амьдрал зөвхөн Их Эзэний хүсэлд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Өө Эзэн намайг удирдаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний хүссэн газарт би очихыг хүсэж байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэн удирдсанаар дуулгавартайгаар амьдръя"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хүчгүй сул дорой намайг Та хэрэглээч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний хаанчлал Түүний зөвт байдлын төлөө"
              }
            ],
            "indent": 0
          },
          {
