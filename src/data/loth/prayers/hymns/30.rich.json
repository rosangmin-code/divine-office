            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Надтай үргэлж хамт байгаасай"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэн минь Таныг дагаж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эргэж буцахгүй шийдлээ би"
