        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч Эзэний нандин тэр цус Ариун тахил юм"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Урсан байна урсан байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эрхэм Эзэний минь цус"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Баяртайгаар бид дуугаа дуулаад"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хүч чадлыг үргэлж авна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ариун сүнсний агуу хүч чадлаар"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ялалтыг байгууллаа"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хуран цуглаад магтан дуулах"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний дагалдагч юм"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бялхан байна бялхан байна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ариун сүнсний хүрхрээ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Их Эзэний дотор, Ялалтыг байгуулцгаая"
              }
            ],
            "indent": 0
          }
