        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дахилт: Бурхан бол хайр бие биенээ хайрлацгаая"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бурхан бол хайр учир нь хайр Бурханаас ирдэг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ахан дүүс аав ээжийг минь энхрий үрс элбэрэлт"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "ханийг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хэл яриа өөр ч тив тивийн хүмүүсийг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Агуу хайраараа нэг болгожээ"
              }
            ],
            "indent": 0
          }
        ]
