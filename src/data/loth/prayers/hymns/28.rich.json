          {
            "spans": [
              {
                "kind": "text",
                "text": "Алтан нар мөнгөн сарыг, тэнгис далай уудам"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "талыг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Жигүүртэн шувууд ан амьтад бүгдээрээ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Агуу хайраар үзэсгэлэн бүрджээ"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
