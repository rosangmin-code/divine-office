{
  "hymnRich": {
    "blocks": [
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Цангасан сэтгэлийг минь Та ундаалж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Цаглашгүй хайраараа Та тэтгээч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хүн бүхэн Таны тэр хайрыг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хүсэл сэтгэлийн үзүүрт эрж хайна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бидний дунд хайрын булгыг оргилуулаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Таны хайраар амьдарч мөнхөрье"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бидний дунд хүчит мутраа илгээгээч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Таны хаанчлалд хамтдаа оршъё"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бид Таныг магтья бид Таныг хүндэлье"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бид Таныг дуулъя бид Таныг алдаршуулъя"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Баяр баяслын гэрлээ Та тусгаад"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бусдын нүглийг өөртөө аваач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хоосон зүрхийг хайраараа дүүргээд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хоёр гараас минь Та хөтлөөч"
              }
            ],
            "indent": 0
          }
        ]
      }
    ],
