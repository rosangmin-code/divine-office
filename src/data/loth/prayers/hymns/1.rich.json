            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Магад гарган авахаар"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Махбодоо хөсөрт хаяад"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Маныг аврах гэсэн юм."
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Маныг аврах гэсэн юм."
