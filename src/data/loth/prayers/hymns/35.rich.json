        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Гайхамшигт хайр юутай их хайр эгшиг яруу их"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "хайр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Амьдралд төөрсөн мөхөс надад аврал өгөхөөр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "ирлээ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Агуу их хайр юутай их хайр айдас төрүүлсэн их"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "хайр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Итгэл өгсөн тэр нэг мөчид юутай үнэтэй байлаа"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Амьдрал дундуур туулан гарлаа бартаат замаар"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "ч туучлаа"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Явсан газраа эргээд харахад яруу сайхан хайр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "бий"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Өнө мөнх би амьдрах боловч өнөөх хайр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "гэрэлтсээр"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Насан үүрд магтан дуулавч төгсгөл байхгүйг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "ухаарлаа. Амэн."
              }
            ],
            "indent": 0
          }
        ]
      }
