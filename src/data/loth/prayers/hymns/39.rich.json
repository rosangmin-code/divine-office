            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Цэвэр агуй дотор булшлагдаад"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Цогтойгоор дахин амьдрав. Аллэлуяа!"
