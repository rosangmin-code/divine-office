        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ганцхан цогноос гал асч дөл болон дүрэлздэг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "юм."
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Эргэн тойрноо гэрэлтүүлж бүхнийг дулаацуулна"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бурханы хайрыг амссан бол та үүнийг мэдэрнэ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Тэр хайрыг та бусдад хүртээ та үүнийг дамжуул"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хаврын улирал айлчилж харзны ус хайлдаг юм"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Шувууд жиргэн дуулж цэцэг навч дэлбээлнэ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Бурханы хайрыг амссан бол та үүнийг мэдэрнэ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Та дуулахыг хүсэж магтан дуулна та үүнийг"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "дамжуул"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Анд найз нартаа би аз жаргал хүсэн ерөөе"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Та Түүний энэ хайрыг хаана ч байсан амсах болно"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Би Түүнийг уулын оройд гарч хүн бүхэнд түгээнэ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Тэр хайрыг та бусдад хүртээ та үүнийг таниул"
              }
            ],
            "indent": 0
          }
        ]
