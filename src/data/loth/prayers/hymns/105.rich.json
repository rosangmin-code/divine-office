            "spans": [
              {
                "kind": "text",
                "text": "1. Үгээ зүрхэнд минь тариач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Өршөөл нигүүлслээр услаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Та бол бидний Тэнгэрбурхан /х2/"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хайраараа биднийг дүүргээч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Харишгүй итгэлээр өсгөөч"
