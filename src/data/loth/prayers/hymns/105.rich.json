            "spans": [
              {
                "kind": "text",
                "text": "3. Энэрэл хайрынхаа гэрч байлгаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Энэ нутгийн минь гэрэл болгооч"
