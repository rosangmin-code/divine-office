            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Та бол бидний Тэнгэрбурхан /х2/"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Танд итгэсэн итгэлээрээ нэгдсэн"
              }
