            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Би бас туулан өнгөрөөе"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Та намайг удирдаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ариун Аврагч нойрсох үед"
