        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "1.Бидний нүглийг уучилаач, биднийг өршөөгөөч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хайр энэрлээр дүүрэн гараа сунгаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Гэмт амьдралаас минь биднийг татаач"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Гэрэл цацарсан хайраа бидэн рүү тусгаач"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дахилт:Их Эзэн өршөө биднийг өршөө"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Христ Эзэн өршөө биднийг өршөө"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Гэм нүглээс хол баймаар байна биднийг өршөө"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хайр энэрэл авмаар байна өршөө"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "2.Бидний амьдралыг заагаач биднийг хайрлаач"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хийсэн гэм нүглийг минь уучилж өршөөгөөч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Мөнхийн мөнхөд хайрлах бидний Их Эзэн"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Муу бүхнээс зайлуулж ивээлдээ аваач"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
