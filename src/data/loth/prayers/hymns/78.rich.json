{
  "hymnRich": {
    "blocks": [
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Сонсооч сонсооч сайхан үг сонсооч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Өвлийн хүйтэн тэр шөнө"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Ер бусын элч ирээд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Анхны энэ мэдээг энэ дэлхийд зарлаж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хээр талын ядуу хоньчдод"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Хөөр баярыг авчирсан"
              }
            ],
            "indent": 0
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дахилт: Сонсооч сонсооч та бүгд сонсооч"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Энэ хорвоогийн Аврагч Эзэн төрлөө"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Дорно зүгт тэр од туяарч хөх тэнгэрт аялан"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Орчлон дэлхий дээгүүр өдөр шөнөгүй гийнэ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Гурван мэргэн алсаас гарч холын одыг дагасаар"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч Эзэнийг үзэхээр алс холоос ирлээ"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Баруун хойшоо аялагч од Бетлехемд хүрч ирээд"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч Хүүгийн гэрийн дээр аядуухан тогтлоо"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Мэргэн гурав Хүүг хараад өвдөг сөгдөн мэндэлж"
              }
            ],
            "indent": 0
          },
          {
            "spans": [
              {
                "kind": "text",
                "text": "Үнэт бэлэг өгөөд Их Эзэнийг хүндлэв"
              }
            ],
            "indent": 0
          }
        ]
      }
    ],
