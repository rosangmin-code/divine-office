  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурханы үг бидэнтэй хамт амьдрахаар Өөрийгөө юу ч үгүй болгон байж ирсэн бөгөөд ингэснээр бид Түүний сүр жавхланг харж болно. Итгэл найдвар дотор баясан, Түүнийг ийн дуудацгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Иммануел, Та бидэнтэй хамт байгаарай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Зөв, шударга удирдагч"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Зовогсод хийгээд гачигдагчдад шударга ёсыг хайрла."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Амар амгалангийн Хаан, Та илдийг анжисны хошуу, жадаа хадуур болгон хувиргадаг тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өшөө хорслыг маань хайр, зовлон шаналлыг маань уучлал болгон хувиргана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та гаднах төрхөөр нь шүүдэггүй тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өөрийн хүмүүсийг таньж мэд."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таныг үүлэн дээрээс хүч чадал, эрх мэдэлтэйгээр ирэх үед"
