        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Тэнгэрбурхан бидний Эцэг минь, Та энэ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "дэлхийг ихэд хайрласан тул Та биднийг хийсэн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "гэм нүглээс маань болон үхлийн хүчнээс"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "чөлөөлөхийн тулд Өөрийн цорын ганц Хүүг"
