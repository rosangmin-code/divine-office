      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидэнд өгсөн. Түүний ирэлтийг хүлээж буй"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "тэдгээр хүмүүст туслан, Жинхэнэ эрх чөлөө рүү биднийг хөтөлнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
