        "kind": "para",
        "spans": [
          {
            "kind": "response",
            "text": "Хүч чадлын Тэнгэрбурхан минь, Та ирээд, биднийг чөлөөлнө үү."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "versicle",
            "text": "Та нүүр царайгаа гэрэлтүүлээч, Тэгвэл бид аврагдана."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "response",
            "text": "Хүч чадлын Тэнгэрбурхан минь."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эцэг, Хүү, Ариун Сүнсийг магтан дуулъя."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
