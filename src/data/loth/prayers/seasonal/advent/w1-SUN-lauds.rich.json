            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ариун Сүнсээр дүүрэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн, Таны Хүү бүх сүр жавхлангаа илчлэх хүртэл"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
