    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн Есүс Христэд болон илчлэлтэд баяр хөөртэйгөөр найдан хүлээх ивээлийг бидэнд өгсөн Тэнгэрбурхан Эцэгт хандан бүгдээрээ ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Та өршөөлөө бидэнд үзүүлнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бидний оюун ухаан, бие махбодыг ариусгана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өөрийн Хүүгээ ирэх хүртэл биднийг гэм нүгэлгүй байлгана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та эдгээр өдрүүдэд биднийг ариун байдал дотор алхуулж,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Зөвт бөгөөд сүсэг бишрэлтэй амьдралаар энэ дэлхийд амьдруулна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бид Эзэн Есүс Христээр хувцаслаж"
