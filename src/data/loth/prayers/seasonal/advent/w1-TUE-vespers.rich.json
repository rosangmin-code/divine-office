  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христ Есүсийн дотор та нарт өгөгдсөн Тэнгэрбурханы нигүүлслийн улмаас та нарын талаар би үргэлж Тэнгэрбурхандаа талархдаг. Учир нь та нар аливаа үг, аливаа мэдлэгээр юм бүгдэд Түүний дотор баяжсан бөгөөд та нарын дунд Христийн талаарх гэрчлэл батажсан учраас бидний Эзэн Есүс Христийн илчлэлийг хүлээхдээ та нар ямар ч бэлгээр эс дутна. Тэр та нарыг Эзэн Есүс Христийн маань өдөр гэм зэмгүй байлгахаар төгсгөл хүртэл бататгана. Өөрийн Хүү, бидний Эзэн Есүс Христийн нөхөрлөлд та нарыг дуудсан Тэнгэрбурхан итгэмжит юм."
          }
        ]
      }
    ],
