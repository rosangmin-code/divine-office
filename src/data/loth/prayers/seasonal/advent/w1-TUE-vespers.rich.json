  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Бидэнд шинэ бөгөөд амьдын замыг илчлэхийн тулд хүн болсон мөнхийн Үгэнд бүгдээрээ эгэл даруухнаар ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь ирэгтүн! Биднийг аврагтун."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурхан, бид Таны дотор амьдарч, хөдөлж, оршин тогтдог тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та биднийг Өөрийн ард түмэн болгосон тухайгаа ирээд, бидэнд зааж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бид бүхний хэнээс нь ч холгүй байгаа тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таныг хайж байгаа бүх хүнд өөрийгөө харуулна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Ядуу хүмүүсийн эцэг, зовогсдыг тайтгаруулагч аа,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та боолуудыг чөлөөлж, гашуудагсдыг баясган цэнгүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та үхлийг үзэн ядаж, амьдралыг хайрладаг тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бүх хүн төрөлхтнийг мөнхийн үхлээс чөлөөлнө үү."
              }
            ]
          }
        ]
      }
