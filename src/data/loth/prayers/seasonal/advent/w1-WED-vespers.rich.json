{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Тэнгэрбурхан Эзэн минь, Христийг сүр жавхлантайгаар ирэх цагт нь хүлээн аваад, тэнгэрийн орны зоогийг Түүнтэй хамт хуваалцахад нь биднийг бэлэн болгоно уу. Тэнд Тэрээр Тэнгэр Эцэг тантай болон Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг ганц Тэнгэрбурхан билээ."
          }
        ]
      }
    ],
    "page": 568,
    "source": {
      "kind": "seasonal",
      "season": "ADVENT",
      "weekKey": "1",
      "dayKey": "WED",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Бидэнд цаглашгүй амар амгаланг авчрахын тулд Өөрийн Хүүгээ илгээсэн Эцэг Тэнгэрбурхандаа ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн, Таны хаанчлал орших болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Дээдийн ариун Эцэг минь, Та Өөрийн Шашныг нигүүлсэн харна уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Өөрийн баруун мутраар тарьсан энэ усан үзмийн талбайдаа зочилж ирнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн, Та Абрахамын бүх хөвгүүдийг таалан болгоно уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэдний өвөг дээдэст хийсэн амлалтуудаа биелүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Нигүүлсэнгүй Тэнгэрбурхан минь, Та хамаг үндэстнүүдийн эрэгтэй эмэгтэйчүүдийг таалан болгоно уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэд Таны сайн сайхны төлөө Таныг хүндэтгэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Мөнхийн Хоньчин минь, Та Өөрийн хонин сүрэг дээр очно уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэдгээр хоньдоо нэг дор цуглуулна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Энэ ертөнцөөс хальж, Таны амар амгаланд очсон хүмүүсийг Та эргэн санана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэднийг Өөрийн Хүүтэйгээ хамт алдаршуулна уу."
              }
            ]
          }
        ]
      }
    ],
