{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эцэг минь, бидэнд Таны тусламж хэрэгтэй байна. Биднийг гэм нүглээс маань чөлөөлж, амьдралд хүргэнэ үү. Та Өөрийн хүч чадлаар"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "биднийг тэтгэнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болтугай."
          }
        ]
      }
    ],
    "page": 571,
    "source": {
      "kind": "seasonal",
      "season": "ADVENT",
      "weekKey": "1",
      "dayKey": "THU",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эш үзүүлэгчдийн амласан агуу гэрэл болох Христ, үхлийн сүүдэрт амьдарч байгаа тэдгээр хүмүүсийн төлөө дуу хоолойгоо өргөн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн Есүс ээ, Та ирэгтүн!"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурханы Үг ээ, Та эхэн цагт хамаг зүйлийг бүтээсэн бөгөөд цаг нь болоход хүмүүн бидний мөн чанарыг Өөртөө авсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та ирэгтүн! Биднийг үхлээс гэтэлгэгтүн."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хүн төрөлхтний дээр гэрэлтэж буй Үнэн гэрэл минь,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та ирэгтүн! Бидний харанхуйг арилгагтун."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эцэгийн зүрх сэтгэлд оршдог цорын ганц Хүү,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та ирэгтүн! Тэнгэрбурханы хайрын болон нинжин сэтгэлийн тухай бидэнд хэлэгтүн."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Христ Есүс ээ, Та бидний дунд \"Хүний Хүү\"-гийн дүр төрхөөр ирсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таныг таньж мэддэг хүмүүсийг Тэнгэрбурханы хөвгүүд болгон хувиргана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таныг дуудаж байгаа тусламж шаардагдсан хүмүүсийг Та хүлээн авдаг тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таны хаалган дээр ирээд гуйж байгаа хүмүүсийг хуримын цайллагадаа оруулна уу."
              }
            ]
          }
        ]
      }
    ],
