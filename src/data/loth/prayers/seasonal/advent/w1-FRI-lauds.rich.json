{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Есүс, бидний Эзэн, биднийг гэм нүглээс маань аврагтун. Ирэгтүн! Биднийг бүх аюулаас хамгаалж, авралын зам руу удирдагтун."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Учир нь Та Тэнгэр Эцэгтэй болон Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг ганц Тэнгэрбурхан билээ."
          }
        ]
      }
    ],
    "page": 575,
    "source": {
      "kind": "seasonal",
      "season": "ADVENT",
      "weekKey": "1",
      "dayKey": "FRI",
      "hour": "lauds"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурхан Эцэг, Өөрийн Хүүгээр уламжлан эрэгтэй, эмэгтэй хүмүүст Өөрийн сүр жавхланг илчилсэн тул бидний баяртай дуу хоолой цуурайтах болтугай. Эзэн, Таны нэр алдар алдарших болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурханы сүр жавхлангийн төлөө Христ биднийг хайрласны адилаар"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Эзэн, бидэнд бие биеэ хайрлахыг зааж өгнө."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг итгэл доторх баяр баясгалан, амар амгалангаар бялхаана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид Ариун Сүнсний хүч чадал, горьдол найдвар дотор алхах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн, Та Өөрийн энэрэл нигүүлслээр бүх хүн төрөлхтөнд тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Үүнийг мэдэхгүйгээр Таныг хайж байгаа хүмүүстэй Та ойр байгаарай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та сонгогдсон хүмүүсийг дуудаж, ариусгадаг билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Хэдийгээр бид нүгэлтнүүд боловч мөнхийн аз жаргалын титмийг бидэнд өмсгөнө үү."
              }
            ]
          }
        ]
      }
    ],
