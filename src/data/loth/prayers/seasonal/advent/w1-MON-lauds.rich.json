  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Олон ард түмэн ирээд “Ирцгээ, ЭЗЭНий уул, Иаковын Тэнгэрбурханы өргөө рүү явцгаая. Тийнхүү Тэрээр бидэнд замаа зааж, бид жимээр нь алхах юм” гэцгээнэ. Учир нь хууль Сионоос гарч, ЭЗЭНий үг Йерусалимаас гарна. Үндэстнүүдийн хоорондохыг Тэр шүүж, Олон ард түмэнд шийдвэр гаргах болно. Тэд илдээ анжисны хошуу, жадаа хадуур болгон давтана. Үндэстэн үндэстнийхээ эсрэг илд далайхгүй, Дахин хэзээ ч тэд дайтахад суралцахгүй."
          }
        ]
      }
    ],
