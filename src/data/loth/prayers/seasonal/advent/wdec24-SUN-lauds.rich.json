          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "versicle",
            "text": "Дэлхийн Аврагч бидний хаан болох болно."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "response",
            "text": "Дэлхийн гэм нүглийн байдал устгагдах болно."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эцэг, Хүү, Ариун Сүнсийг магтан дуулъя."
