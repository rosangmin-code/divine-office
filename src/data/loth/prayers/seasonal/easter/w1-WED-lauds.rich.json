  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эцэгийнхээ хайрласан хишгээр уламжлан амилсан Христ элч нарт харагдсан тул Эцэгт нь хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн, Та Хүүгийнхээ сүр жавхланг бидэнд хайрлан соёрхоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Гэгээн гэрлийн Эцэг минь, Та өршөөл нигүүлслээ бидэнд хүртээхийн тулд биднийг Өөрийнхөө гайхамшигтай гэрэлд оруулахаар дуудсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өнөөдөр бид Танд талархал магтаалаа өргөж байна."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Манай дэлхий ертөнцийг илүү хүмүүнлэг болгохын тулд хүн төрөлхтний гаргасан хүчин чармайлтыг"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таны Сүнсний ид хүчээр ариутгаж, хүчирхэгжүүлэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бүх хүн төрөлхтний гэр бүлийг Таны хүндэтгэлд тааламжтай золиослол болгохын тулд"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бид бусдад үйлчлэхэд өөрсдийгөө зориулах болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Шинэ өдөр эхэлмэгц биднийг өршөөлөөрөө дүүргэнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тиймийн тул энэхүү бүтэн өдөр баяр баясгалан, магтаалын өдөр байх болно."
              }
            ]
          }
        ]
      }
    ],
