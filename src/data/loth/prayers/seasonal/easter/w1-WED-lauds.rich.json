  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Хэрэв бид Христтэй хамт үхсэн бол мөн Түүнтэй хамт амьдрах болно гэдэгтээ итгэдэг. Түүнчлэн Христ үхэгсдээс амилуулагдсан тул дахиж хэзээ ч үхэхгүйг бид мэднэ. Үхэл цаашид Түүнийг захирахгүй. Учир нь Тэрээр үхэхдээ нүглийн хувьд нэгмөсөн үхсэн бөгөөд харин Түүний амьдардаг амьдралын хувьд, Тэрээр Тэнгэрбурханд амьдардаг юм. Яг түүнчлэн та нар өөрсдийгөө нүглийн хувьд үхсэн бөгөөд Тэнгэрбурханы хувьд Христ Есүсээр амьд байгаа гэж тооц."
          }
        ]
      }
    ],
