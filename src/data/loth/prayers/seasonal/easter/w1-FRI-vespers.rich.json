{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, мөнхийн Эцэг минь, Та Амилалтын далд нууцыг эвлэрлийн эвслийн гэрээ маань болгож, бидэнд хайрласан юм. Бидний ёслон тэмдэглэж буй энэхүү шинэ төрөлт нь бидний амьдралын хэв маягт өөрийн үр нөлөөг харуулах болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний Эзэн, Таны Хүүгээр уламжлан тийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болтугай."
          }
        ]
      }
    ],
    "page": 726,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "FRI",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христ бол зам, үнэн, амь мөн. Түүнийг магтан дуулж, ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Амьд Тэнгэрбурханы Хүү, Та ард түмнээ адисалж өгнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Есүс минь, таны Шашны бүх санваартан нарын төлөө бид Танд залбирч байна."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэд амьдралын талхыг бидний төлөө хуваадаг тул тэд өөрсдөө шим тэжээл, хүч чадлыг хүлээн авах болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хамаг Христийн сүсэгтнүүд дуудлагадаа зохистой байхын төлөө бид залбирч байна."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Ариун Сүнсний доторх тэдний эв нэгдлийг амар амгалангийн холбоогоор хамгаална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг удирддаг хүмүүс энэрэл нигүүлсэл, шударга ёсыг эрхэмлэн ажиллах бөгөөд"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Дэлхий даяар эв нэгдэл, энх тайвныг бэхжүүлэхийн төлөө бид залбирч байна."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бидний зүрх сэтгэл гэгээнтнүүдийн нэгдэлд Таны магтаалыг дуулахаар цэвэршүүлэгдэхийн ариусгагдахын төлөө бид өөрсдийнхөө төлөө залбирч байна."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таны хайр халамжид даатгаж буй өөд болсон хайрт ах эгч дүү нартайгаа бид дахин уулзаж, нэгдэх болтугай."
              }
            ]
          }
        ]
      }
    ],
