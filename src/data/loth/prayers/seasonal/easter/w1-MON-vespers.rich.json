{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, өршөөнгүй Тэнгэрбурхан минь, бидний Таны Хүүгийн амилалтыг ёслон тэмдэглэж буй эл баяр ёслол бидний амьдралд бодит үр нөлөөтэй байдгийг мэдрүүлэхэд тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 709,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "MON",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Амилалтаараа уламжлан дэлхий ертөнцийг цог жавхлангаар дүүргэсэн Эзэн Христэд залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Баяр хөөр дүүрэн сэтгэлээр ийн хэлцгээе. Бидний амь болсон Христ минь, бидний залбирлыг сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Есүс Христ минь, Та дагалдагч нартайгаа хамт зам дагуу алхаж байсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Амьдралын эргэл мөргөлийн турш Өөрийн Шашинтай хамт байна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та биднийг итгэхдээ удаан бүү байлгана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Харин биднийг Таныг үхлийн ялагч хэмээн тунхаглахад бэлэн байлгана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны оршихуйг үл танин мэдэгч хүмүүсийг Та нигүүлсэнгүй харж үзнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэдэнд Та Өөрийгөө илчилнэ үү. Ингэснээр тэд Таныг Аврагч хэмээн хүлээн авах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Загалмайгаар дамжуулан Та Өөрийн биеэрээ хүн төрөлхтнийг Тэнгэрбурхантай эвлэрүүлсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бүх үндэстнүүдийг амар тайван, эв нэгдлээр нэгдэхэд тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Амьд болон үхэгсдийг Шүүгч Та,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Итгэлт талийгаачдын гэм нүглийг өршөөнө үү."
              }
            ]
          }
        ]
      }
    ],
