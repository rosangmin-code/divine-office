        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Бидний хэн нь ч өөрийнхөө төлөө амьдардаггүй. Хэн нь ч өөрийнхөө төлөө үхдэггүй. Бид амьдарлаа ч Эзэний төлөө амьдардаг. Бид үхлээ ч Эзэний төлөө үхдэг. Тиймээс амьдарсан ч, үхсэн ч бид Эзэнийх. Учир нь үхсэн амьд аль алиных нь Эзэн байхын тулд, чухам үүний төлөө Христ үхээд амилсан билээ."
          }
        ]
