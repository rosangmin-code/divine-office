{
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христ бол амийн талх. Тэрбээр сүүлчийн өдөр Түүний бие болон үгийг хуваалцаж байсан тэдгээр бүх хүмүүсийг босгон амилуулна. Баяр хөөртэйгөөр Түүнд ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Та бидэнд амар амгалан, баяр баясгаланг хайрлан соёрхоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурханы Хүү, Та биднийг амь руу удирдахын тулд үхлээс амилсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Эцэгийнхээ бүх охид хөвгүүдийг адисалж, мөн ариусгана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та, Танд итгэдэг бүх хүнд амар амгалан, баяр баясгаланг хайрладаг тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг гэрлийн охид хөвгүүдийн хувиар Таны ялалтад баяртайгаар алхахад ивээж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Дэлхий дээр залбиран мөргөж буй Шашныхаа итгэл бишрэлийг Та бэхжүүлнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид дэлхий даяар Таны амилалтыг гэрчлэх болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бүх зовлонг эдлэн, Эцэгийнхээ сүр жавхланд орсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та зовлонгийн нулимсыг баярын нулимс болгож эргүүлнэ үү."
              }
            ]
          }
        ]
      }
    ],
    "page": 729,
    "source": {
