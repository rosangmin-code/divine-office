{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эзэн минь, бид Таны Хүүгийн амилалтыг"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "ёслон тэмдэглэж буй лугаа адил Түүнийг сүр"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "жавхланд нь буцан ирэхэд хамаг гэгээнтнүүдтэй"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "хамт баярлан цэнгэх болтугай. Тэрээр Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг цорын ганц Тэнгэрбурхан билээ."
          }
        ]
      }
    ],
    "page": 717,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "WED",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Хүүгээ үхэгсдээс амилуулснаар Тэнгэрбурхан мөнх аминд хүргэх замыг бидний төлөө нээсэн тул Тэнгэрбурхан Эцэгээс гуйн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Христийн ялалтаар цагаатгасан ард түмнийг Та аварна уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бидний эцэг өвгөдийн Тэнгэрбурхан, Та Өөрийн Хүү Есүсийг үхэгсдээс амилуулж, сүр жавхлангаар хувцасласан тул Та бидний зүрх сэтгэлийг бүрэн төгс гэмшлийн зүг хөтөлнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид шинэ амьдралын замаар алхах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та биднийг бидний сүнсний хоньчин руу буцаан удирдсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг Шашныхаа хоньчны удирдлаган доор итгэлтэй, үнэнч байлгана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Христийн анхны шавь нарыг еврей хүмүүсээс сонгосон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Израилын өвөг дээдэст нь өгсөн амлалтын биелэлтийг хүүхдүүдэд нь илчилнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Өнчин, өргөмөл, ганцаараа байгаа хүмүүс болон бэлэвсэн эмэгтэйчүүдийг Та дурсан санана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таны Хүүгийн үхлээр дамжуулан Тантай эвлэрүүлсэн хүмүүсийг Та бүү орхиоч."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Стефаныг Таны баруун талд зогсож байсан Есүсийн тухай гэрчлэхэд Та түүнийг Өөрийн оршихуйд амьдрахаар дуудсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таны сүр жавхланг харахыг хайраар дүүрэн, итгэлтэйгээр эрмэлзэж байсан талийгаач ах, дүү нарыг минь Та хүлээн авна уу."
              }
            ]
          }
        ]
      }
    ],
    "page": 718,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "WED",
      "hour": "vespers"
    }
  }
}
