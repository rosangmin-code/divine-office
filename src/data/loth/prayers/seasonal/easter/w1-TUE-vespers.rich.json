{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Тэнгэрбурхан Эцэг минь, Та биднийг Өөрсдийн охид хөвгүүд болгосон бөгөөд бидний залуу насны баяр баясгаланг сэргээсэн тул бид найдвар дүүрэн өөрсдийнхөө амилалтыг хүсэн хүлээх болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний Эзэн, Таны Хүүгээр уламжлан тийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болтугай."
          }
        ]
      }
    ],
    "page": 713,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "TUE",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христ амилалтаараа Өөрийн ард түмэнд бат итгэл найдварыг хайрласан билээ. Бүх зүрх сэтгэлээсээ Түүнд хандан ийн залбиран гуйцгаая. Эзэн Есүс минь, Та үүрд мөнх амьд билээ. Бидний залбирлыг сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Есүс минь, Таны хажуу хавирганаас ус ба цус урссан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Өөрийн Шашныг хир толбогүй сүйт бүсгүйгээ болгож өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Ахлах хоньчин минь, Та амилалтынхаа дараа Петрийг Танд зориулсан хайраа илчлэхэд түүнийг хонин сүргийнхээ хоньчноо болгосон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Манай Пап лам нарын хайр энэрэл ба сүсэг бишрэлийг өдрөөс өдөрт нэмэгдүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та шавь нартаа загасчлал хэрхэн бүтэмжтэй, ихтэй болохыг үзүүлсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Хүний загасчид болохын хувьд тэдний ажлыг үргэлжлүүлэн хийлгэхээр Та шинэ хүмүүсийг илгээнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та нуурын эрэг дээр дагалдагч нартаа зориулан талх ба загас бэлтгэсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бусад хүмүүсийг хэзээ ч өлсгөлөнгөөр үхүүлэхгүй байхад бидэнд тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Амьдралыг тэтгэгч сүнс, шинэ Адам, Есүс минь, талийгаач бологсдыг Өөртэйгөө адилхан болгон хувиргана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр таны баяр баясгалан тэднийх болох болно."
              }
            ]
          }
        ]
      }
    ],
