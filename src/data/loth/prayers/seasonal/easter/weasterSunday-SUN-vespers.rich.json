{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Тэнгэрбурхан бидний Эцэг минь, Та Өөрийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Хүү Христийг амилуулснаараа үхлийн эрх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "мэдлийг булаан авсан бөгөөд бидэнд мөнх амийн замыг нээж өгсөн билээ. Өнөөдрийн бидний тэмдэглэж байгаа их баяр бидний дотор байгаа Сүнсээр дамжуулан биднийг амилуулж, мөн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний амьдралыг шинэчлэх болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 692,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "easterSunday",
      "dayKey": "SUN",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Амьсгал хурааж, амилсан бөгөөд цаг ямагт бидний төлөө зуучлан залбирахаар амьдардаг Эзэн Христийг баяр дүүрэн сэтгэлээрээ ийн дуудацгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Ялагч Хаан минь, Та бидний залбирлыг сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хамаг ард түмний гэрэл болон Аврагч минь,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг Таны амилалтыг тунхаглаж байхад Та Сүнснийхээ галаа бидний зүрх сэтгэл рүү илгээнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Израиль нь Таныг удаан хүсэн хүлээсэн Аврагч мэтээр танин мэдэх болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн бүх газар дэлхий Таны сүр жавхлангийн тухай мэдлэгээр дүүрэн байх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та биднийг гэгээнтнүүдийнхээ нэгдэлд багтааж, хадгална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн тэдний нөхөрлөлд зүтгэлийн амралтыг маань хайрлан соёрхоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийн дайсан болсон үхлийг ялан дийлсэн тул үхлийн эрх мэдлийг бидний дотор устгана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тиймээс бид үхэшгүй мөнхийн Эзэн болон ялагч зөвхөн Таны төлөө амьдрах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч Христ, Та үхэлд хүртэл дуулгавартай болсон бөгөөд Эцэгийн баруун гар талд заларсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та ахан дүүс нараа нигүүлсэж, сүр жавхлангийнхаа хаанчлалд хүлээн авна уу."
              }
            ]
          }
        ]
      }
    ],
