  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христ Эзэн Ариун Сүнсээр дамжуулан Өөрийн Шашныг нэгтгэсэн. Найдвар дүүрэн Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн, Та бүх дэлхий ертөнцийг шинэчилнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Есүс, Таны загалмай дээр өргөгдсөн үед Таны жадалсан хажуу хавирганаас амийн усны урсгал урссан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Амийг хайрлагч Сүнсийг бидэн дээр буулгаж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурханы баруун гар дахь сүр жавхлангийн дотор Та Эцэгийнхээ хишгийг шавь нартаа хайрласан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Дэлхий ертөнцийг шинэчлэхийн тулд Өөрийн Сүнсийг илгээнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та гэм нүглийг өршөөх эрх мэдэлтэй Сүнсийг шавь нартаа өгсөн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Энэ дэлхий ертөнц дэх бүх гэм нүглийг устгана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бидэнд бүгдийг заах бөгөөд бидэнд хэлсэн бүгдийг тань сануулахын тулд Та, Ариун Сүнсийг бидэнд илгээнэ хэмээн амласан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний оюун ухааныг итгэл бишрэлээр дамжуулан гийгүүлэхийн тулд Та Сүнсээ бидэнд илгээнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийгөө гэрчлүүлэхийн тулд үнэний Сүнсийг илгээнэ хэмээн амласан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг Таны үнэнч гэрчлэгч нар болгохын тулд Та Сүнсээ бидэнд илгээнэ үү."
              }
            ]
          }
        ]
      }
    ],
