  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурхан Түүнийг үхэгсдээс амилуулсан бөгөөд Тэр Галилаас Йерусалимд Өөртэй нь хамт ирсэн хүмүүст олон хоногийн турш үзэгдсэн юм. Эдүгээ тэд л ард олны өмнөх Түүний гэрч нар юм. Бид эцэг өвгөдөд ирсэн амлалтын сайнмэдээг та нарт тунхаглаж байна. Дуулал номын хоёрдугаарт “Чи Миний Хүү, өнөөдөр Би Чамайг төрүүлэв” гэж бичигдсэнчлэн Есүсийг амилуулснаар Тэнгэрбурхан амлалтаа бидний хүүхдүүдэд биелүүлж өгсөн юм."
          }
        ]
      }
    ],
