{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Тэнгэрбурхан Эцэг минь, Та биднийг Өөрсдийн охид хөвгүүд болгосон бөгөөд бидний залуу насны баяр баясгаланг сэргээсэн тул бид найдвар дүүрэн өөрсдийнхөө амилалтыг хүсэн хүлээх болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний Эзэн, Таны Хүүгээр уламжлан тийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болтугай."
          }
        ]
      }
    ],
    "page": 713,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "TUE",
      "hour": "lauds"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурханы өө сэвгүй Хурга дэлхийн гэм нүглийг арилгадаг тул Эцэгт талархлаа илэрхийлж, Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Бүх амьдралын эх булаг минь, Та биднийг амилуулна уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бүх амьдралын эх булаг минь, Та загалмай дээр цовдлуулсан Хурганы үхэл болон амилалтыг эргэн санана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний төлөө зуучлан залбирдаг үүрд мөнхөд амьд оршигч Түүний дуу хоолойг Та сонсоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эдүгээ хорсол ба муу ёрын хуучин хөрөнгө устгагдаж байгаа тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бид чин сэтгэлийн ба үнэний исгээгүй талхаар үргэлж хооллож байх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Өнөөдөр биднийг атаа жөтөө, хэрүүл тэмцлээс ангид байлгаж,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн бусдын хэрэгцээг илүү анхаарахад Та тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бидний сэтгэл зүрхэнд Та Айлдлын сүнсийг илгээнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид өнөөдөр болон цаашид ч үүрд мөнх Таны зарлигийн замаар алхах болно."
              }
            ]
          }
        ]
      }
    ],
