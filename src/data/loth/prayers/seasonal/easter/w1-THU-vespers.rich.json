{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эцэг минь, Таны бидний Эзэн Есүс Христийг сүр жавхланд амилуулсны төлөө бид үргэлж Танд талархлыг өргөж байх болтугай. Учир нь бид ард түмэн бөгөөд Түүний ялсан авралыг хуваалцдаг"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "юм."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэрээр Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг цорын ганц Тэнгэрбурхан билээ."
          }
        ]
      }
    ],
    "page": 724,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "THU",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эцэг бидний горьдол найдварын үндэс суурь болон бидний амилалтын эх үндсийг Христ дотор тогтоосон билээ. Тиймийн тул Христ дотор баярлацгааж, Түүнд ийн хандан хашхирцгаая. Сүр жавхлангийн Хаан, Та бидний залбирлыг сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Есүс, Та амилалтаараа дамжуулан Өөрийн цусыг өргөхийн тулд тэнгэрийн оронд орсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та биднийг Өөртэйгөө хамт Эцэгийнхээ сүр жавхлан руу удирдана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та амилалтаараа дамжуулан дагалдагч нарынхаа итгэлийг бататгасан бөгөөд тэднийг дэлхий рүү Сайнмэдээний айлдлыг тунхаглуулахаар илгээсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та бүх хамба лам болон санваартнуудыг сайнмэдээний үнэнч номлогч нар болгож өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та амилалтаараа дамжуулан бидний эвлэрэл болон амар амгалан болсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та усан угаал хүртсэн хүмүүсийг төгс итгэл, хайрын нэгдэл дотор нэгтгэж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны амилалтаар дамжуулан тахир дутуу хүн ариун сүмийн хаалган дээр эдгэрсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та өвчтэй хүмүүсийг харж хандан, тэдний дотор сүр жавхлангийнхаа ид хүчийг илчилнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та үхэгсдээс анх төрсөн Нэгэн, амилалтын анхны үр шим болсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Танд итгэж найдаж байсан талийгаачидтай хамт Та сүр жавхлангийнхаа хувь заяаг хуваалцана уу."
              }
            ]
          }
        ]
      }
    ],
