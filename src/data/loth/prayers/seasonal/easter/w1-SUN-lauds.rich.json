{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, мөнхийн Тэнгэрбурхан минь, биднийг Эзэний амилалтыг тохиолдуулан өөрсдийн баяр баясгаланг ёслон тэмдэглэж, мөн ёслон тэмдэглэж буй хайрыг өөрсдийн амьдралаараа илэрхийлэхэд тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 702,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "SUN",
      "hour": "lauds"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Төгс хүчит Эцэг Тэнгэрбурхан Есүсийг үхлээс амилуулснаараа үхэгсдээс анх төрсөн Нэгэн болгосон бөгөөд Түүнийг бидний Аврагчаар өргөмжилсөн тул бүгдээрээ Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн, Та Хүүгийнхээ сүр жавхланг бидэнд хайрлан соёрхоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Туйлын Ариун Эцэг минь, Та хамгаас хайртай Хүүгээ үхлийн харанхуйгаас гаргаж, сүр жавхлангийнхаа гоо үзэсгэлэн рүү авчирсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг ч бас гайхамшигт гэрэл гэгээ рүүгээ аваачна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та биднийг аврахын тулд итгэл өгсөн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бид өнөөдөр Ариун угаалынхаа итгэлээр амьдрах болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны баруун гар Талд заларч байгаа Христийн байгаа газарт дээгүүрхийг хай хэмээн бидэнд тушаасан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Хүний дур сэтгэлийг татах даллах гэм нүглийн хүчид биднийгээ бүү орхиоч."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Христтэй хамт Тэнгэрбурханд нууцлагдсан бидний амь дэлхийн өмнө гэрэлтэх болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн шинэ тэнгэр, шинэ газрыг зөгнөх болтугай."
              }
            ]
          }
        ]
      }
    ],
