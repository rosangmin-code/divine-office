{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, өршөөнгүй Тэнгэрбурхан минь, бидний Таны Хүүгийн амилалтыг ёслон тэмдэглэж буй эл баяр ёслол бидний амьдралд бодит үр нөлөөтэй байдгийг мэдрүүлэхэд тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 709,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "MON",
      "hour": "lauds"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурхан Эцэг Хүүгийнхээ амилалт болон үхэлд алдаршуулагдав. Итгэлтэйгээр Түүнд ийн хандан, залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн бидний оюун ухааныг гэгээрүүлнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Гэгээн гэрлийн Эцэг минь, Та Христийг сүр жавхлангаар амилахад энэхэн газар дэлхийг цог жавхлангаар дүүргэсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өнөөдөр Та бидний оюун ухааныг итгэл бишрэлийн гэгээн гэрлээр бялхаана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Хүүгийнхээ амилалтаар уламжлан бидэнд мөнх амьдралын замыг нээсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өнөөдөр ажиллаж буй биднийг Та тэнгэрлэг найдвараар өргөн тэтгэнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та амилсан Хүүгээрээ уламжлан энэ дэлхий рүү Ариун Сүнсийг илгээсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний зүрх сэтгэлийг сүнслэг хайрын галаар шатаана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг чөлөөлөхийн тулд загалмайд цовдлуулсан Есүс Христ"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний энэ өдрийн аврал ба цагаатгал байх болтугай."
              }
            ]
          }
        ]
      }
    ],
    "page": 708,
