{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, мөнхийн Тэнгэрбурхан минь, биднийг Эзэний амилалтыг тохиолдуулан өөрсдийн баяр баясгаланг ёслон тэмдэглэж, мөн ёслон тэмдэглэж буй хайрыг өөрсдийн амьдралаараа илэрхийлэхэд тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 702,
    "source": {
      "kind": "seasonal",
      "season": "EASTER",
      "weekKey": "1",
      "dayKey": "SUN",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Үхлээс амилснаар Христ үхлийг устгаж, амьдралыг сэргээсэн билээ. Бүгдээрээ Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн Есүс минь, Та мөнх амьтай тул бидний залбирлыг сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та барилгачдын голсон булангийн тулгуур чулуу билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та биднийг ариун нандин Шашныхаа амьд чулуу болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та үхлээс анх амилсан, үнэн, итгэлтэй гэрчлэгч билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Өөрийн Шашныг Өөрийнхөө тухай мөнхийн гэрчлэгч болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бол Өөрийн хажуу хавирганаас төрсөн Шашныхаа гагц сүйт залуу билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та түүнийг энэ дэлхийд сүйт бүсгүй нь сүйт залуудаа хайрыг илчлэгч болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бол эхлэл ба төгсгөл, Та амьсгал хураагаад, амилсан билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та ариун угаал хүртэгчдийг үхэн үхтлээ итгэлтэй, үнэнч болгоно уу. Ингэснээр тэд ялалтын титмийг хүртэх болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бол Тэнгэрбурханы ариун хотын гэрэл ба дэнлүү билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Талийгаач болсон бидний анд нөхдийг Та гэрэлтүүлнэ үү. Ингэснээр тэд үүрд мөнхөд хаанчлах болно."
              }
            ]
          }
        ]
      }
    ],
