    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Амилсан Христээр дамжуулан шинэ амьдралыг бидэнд өгсөн Эцэг Тэнгэрбурханд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Та Хүүгийнхээ сүр жавхланг бидэнд хайрлан соёрхоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Тэнгэрбурхан минь, Таны агуу гайхамшигт үйлс Таны мөнхийн төлөвлөгөөг илчилсэн билээ. Та газар дэлхийг бүтээсэн бөгөөд бүх үеийнхэнд үнэнч байдаг билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өршөөнгүй Эцэг минь, Та бидний залбирлыг сонсоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийн үнэнээр зүрх сэтгэлийг минь ариусгаж, тэднийг ариун байдлын замд хөтөлнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид Таны мэлмийд тааламжтай зүйлсийг хийх болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийн нүүр царайг бидний дээгүүр гийгүүлнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид гэм нүглээс чөлөөлөгдөж, Таны элбэг дэлбэгээр дүүрэх болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та элч нартаа Христийн амар амгаланг өгсөн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та ард түмэндээ болон бүх дэлхийд амар амгаланг хайрлана уу."
              }
            ]
          }
        ]
      }
    ],
