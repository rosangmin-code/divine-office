{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эцэг минь, дөчин хоногийн цаг улирлын сахилгаар уламжлан Таны Хүүгийн үхэл болон амилалтыг бидэнд ойлгоход болон үүнийг амьдралаараа тусгахад тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 620,
    "source": {
      "kind": "seasonal",
      "season": "LENT",
      "weekKey": "1",
      "dayKey": "SUN",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Бүгдээрээ бидний багш, ах болон үлгэр дуурайл болсон Эзэн Христийг алдаршуулцгаая. Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Өөрийн хүмүүсээ Өөрийн амьдралаараа дүүргэнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн Есүс ээ, Та гэм нүглээс бусад бүх зүйлээрээ бидэн шиг болсон тул бусад хүмүүсийн баяр баясгалан, уй гашууг хэрхэн хуваалцахыг бидэнд зааж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бидний хайр өдөр бүр илүү гүнзгийрэх болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг өлссөнийг хооллохдоо Таныг хооллоход тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн цангасныг ундлахдаа Таныг ундлахад тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Лазарыг үхлийн гүн нойрноос сэрээсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та гэм нүглийн үхлээр нас барсан хүмүүсийг итгэл ба наманчлалаар дамжуулан дахин амилах боломжтой болохыг хайрлан соёрхоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Олон хүмүүс Төгс жаргалт Цэвэр Охин Мариа болон хамаг гэгээнтнүүдийн үлгэр дуурайлын дагуу"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таныг илүү их хичээл зүтгэл, төгс төгөлдөр байдлаар даган явахад урамшуулна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Үхэгсэд Таны хайрыг үүрд мөнх эдлэхийн тулд"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Таны сүр жавхлангийн дотор амилах болтугай."
              }
            ]
          }
        ]
      }
    ],
