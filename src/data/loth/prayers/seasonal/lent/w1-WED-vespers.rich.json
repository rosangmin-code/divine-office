{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эзэн минь, биднийг дээрээс харж, залбирлыг минь сонсонө уу. Таны бидэнд нөлөөлсөн буяны үйлсийн ачаар өөрсдийн бие махбодыг журамтай болгож, Сүнсэн дотор шинэчлэгдэхэд Та бидэнд тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний Эзэн, Таны Хүүгээр уламжлан тийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болтугай."
          }
        ]
      }
    ],
    "page": 639,
    "source": {
      "kind": "seasonal",
      "season": "LENT",
      "weekKey": "1",
      "dayKey": "WED",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эцэгийн хувьд биднийг дээрээс харж, сахин хамгаалдаг төгс хүчит Тэнгэрбурхан ерөөлтэй еэ! Тэр бидний бүх хэрэгцээг мэддэг атлаа эхлээд биднийг Өөрийн хаанчлалыг хайгаасай хэмээн бид нараас хүсдэг. Түүний ард түмний хувьд Түүнээс ийн гуйн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Таны хаанчлал орших болтугай, Тиймээс шударга ёс хаанчлах болно."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бүх ариун гэгээн байдлын Эцэг минь, Та бидэнд Христийг бидний сүнсний хоньчин болгон өгсөн тул Та хоньчид болон тэдэнд даатгагдсан хонин сүрэгтэй хамт байж, хонин сүргээ хоньчных нь хайр халамжгүйгээр бүү орхино уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Өөрийн хоньчдыг тэднийг дуулгавартайгаар дагаж явдаг хонин сүрэггүйгээр бүү орхино уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Ядуу дорой хүмүүст хайр халамжаар туслахыг Та Христэд итгэгчдэд зааж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн ядуу дорой хүмүүст үйлчилснээрээ Таны Хүүд үйлчилж байгаа гэдгийг тэдэнд зааж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хараахан үл итгэгчдийг Та Өөрийн Шашиндаа цуглуулна уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн тэднийг Таны хайрын төлөө үйлдсэн сайн үйлсээр нь дамжуулан Шашныг Тань бий болгоход тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Уучлал гуйхын төлөө Тан руу эргэхэд бидэнд тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн Та биднийг уучлахдаа Өөрийн Шашинтай эвлэрүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Талийгаач бологсод энэ ертөнцөөс мөнх амьдралд хүрэх болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэд Тантай үүрд мөнх хамт байх болтугай."
              }
            ]
          }
        ]
      }
    ],
