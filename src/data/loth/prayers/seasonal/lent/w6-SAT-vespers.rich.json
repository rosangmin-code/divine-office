  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Ингэхдээ та нар эцэг өвгөдөөсөө өвлөсөн утгагүй амьдралаас алт, мөнгө мэтийн устах зүйлсээр бус, харин гэм зэмгүй бөгөөд толбогүй хурганых адил Христийн үнэт цусаар золигдсоноо мэдэгтүн. Ертөнцийн сууриас өмнө Тэр урьдаас мэдэгдсэн боловч цаг хугацааны төгсгөлд та нарын төлөө илчлэгдэв. Та нар Түүгээр дамжин Тэнгэрбурханд итгэсэн юм. Тэнгэрбурхан Түүнийг үхэгсдээс амилуулж, Түүнд алдрыг өгчээ. Ингэснээр итгэл хийгээд найдвар чинь Тэнгэрбурханд байх юм."
          }
        ]
      }
    ],
