  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Есүс тарчлалтынхаа өмнө Йерусалимыг хараад уйлав. Учир нь Тэнгэрбурханы түүн дээр айлчлан ирсэн цагийг тэр танин мэдэж авч чадсангүй юм. Гэм нүглүүдийнхээ төлөө гашуудаж, Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Өөрийн хүмүүсээ өршөөнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тахиа дэгдээхэйнүүдээ далавчин дороо бөөгнүүлдэг шиг Та Йерусалимын хүүхдүүдийг Өөртөө цуглуулахыг хэчнээн ч удаа хүссэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та бүх хүмүүст Өөрийн айлчлан ирэх цагийг танин мэдэхийг зааж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таныг орхисон хүмүүсийг бүү орхино уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний зүрх сэтгэлийг Өөр лүүгээ хандуулна уу. Тэгвэл Тэнгэрбурхан минь, бид Тан руу буцан очих болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та тарчлалтаараа дамжуулан дэлхий ертөнцөд хишиг ивээлээ соёрхсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ариун угаалаар бидэнд соёрхсон сүнсээрээ амьдрахад Та тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны тарчлалтаар дамжуулан биднийг өөрсдийгөө үгүйсгэхэд тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн Таны амилалтыг тэмдэглэхэд бэлтгэнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Эцэгийнхээ сүр жавхланд хаанчилдаг тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өнөөдрийн талийгаачдыг дурсан санана уу."
              }
            ]
          }
        ]
      }
    ],
