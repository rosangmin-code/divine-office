    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Биднийг шинэ бүтээл болгохын тулд Эзэн Христ бидэнд дахин төрөх усыг хайрлан соёрхож, Өөрийн биеийн болон үгийнхээ ширээг засаж өгсөн билээ. Түүнийг дуудаж, ийн хандан залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Та биднийг хишиг ивээлээрээ шинэчилнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Даруу бөгөөд дөлгөөн зүрх сэтгэлтэй Есүс минь, биднийг өрөвдөх нинжин сэтгэл, сайхан зан, даруу байдлаар хувцаслаж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг бүх хүнд тэвчээртэй хандахыг хүсдэг болоход тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Зовлон зүдүүрт байгаа бүх хүмүүсийн жинхэнэ хөршүүд байхыг бидэнд зааж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Сайн Самари хүн Таныг дуурайхад тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Цэвэр ариун амьдралаар амьдрахаар сахил хүртсэн бүх хүмүүсийн төлөө Таны Эх төгс жаргалт Цэвэр Охин Мариа залбирах болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр тэд өөрсдийгөө Танд болон Таны Шашинд илүү ихээр зориулах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та өршөөл нигүүлслийнхээ хишгийг соёрхож,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний гэм нүглийг өршөөж, тэдний шийтгэлээс хэлтрүүлнэ үү."
              }
            ]
          }
        ]
      }
    ],
