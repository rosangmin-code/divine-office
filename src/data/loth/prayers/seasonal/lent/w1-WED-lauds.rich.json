{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эзэн минь, биднийг дээрээс харж, залбирлыг минь сонсонө уу. Таны бидэнд нөлөөлсөн буяны үйлсийн ачаар өөрсдийн бие махбодыг журамтай болгож, Сүнсэн дотор шинэчлэгдэхэд Та бидэнд тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "оршин хаанчилдаг Тэнгэрбурхан Есүс Христ"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "бидний Эзэн, Таны Хүүгээр уламжлан тийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болтугай."
          }
        ]
      }
    ],
    "page": 639,
    "source": {
      "kind": "seasonal",
      "season": "LENT",
      "weekKey": "1",
      "dayKey": "WED",
      "hour": "lauds"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Бүх зүйлсийг бий болгох цагт хүн төрөлхтнийг Өөрийн дотор шинэ бүтээл болгохыг зарлигласан авралыг хайрлагч Тэнгэрбурхан ерөөлтэй еэ! Агуу их итгэлтэйгээр Түүнээс ийн гуйцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн, биднийг Сүнсэн дотроо шинэчилнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн, Та шинэ тэнгэр, шинэ дэлхийг амласан тул Сүнсээрээ дамжуулан биднийг өдөр бүр шинэчилнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид тэнгэрлэг Йерусалимд Таны оршихуйд мөнхөд талархах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг Тантай хамт энэ дэлхийг амьд байлгахын тулд Таны Сүнсийг бидэнтэй хамт ажиллахад тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн биднийг дэлхий дээр шударга ёст амар тайван, хайрын хотыг босгон байгуулахад тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг хайхрамжгүй байдал, аливаа залхуурлаас чөлөөлж,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ивээлийнхээ хишгээр баяр баясгаланг хайрлан соёрхоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг муу ёрын сүнснээс чөлөөлж,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Сайн сайхан байдлыг халхалдаг мэдрэмжийн боолчлолоос гаргаж өгнө үү."
              }
            ]
          }
        ]
      }
    ],
