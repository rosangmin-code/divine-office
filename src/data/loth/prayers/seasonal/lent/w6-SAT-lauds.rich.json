  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн ийн айлдав: Зовлон шаналал дундаа тэд Намайг хичээнгүйлэн хайх болно. Ирцгээ, Эзэн рүү буцаж явцгаая. Учир нь Тэр биднийг хэсэгчлэн тастсан боловч илаарьшуулах болно. Тэр биднийг гэсгээн гэсгээсэн боловч бидний шархыг боох болно. Хоёр хоногийн дараа Тэр биднийг амилуулж, Гурав дахь хоногтоо биднийг сэргээх болно."
          }
        ]
      }
    ],
