{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эзэн минь, бидний Дөчин хоногийн цаг"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "улирлын сахилга биднийг шинэчлэхэд тусалж,"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христийн үхэл болон амилалтыг тэмдэглэхэд биднийг бэлтгэх болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэрээр Тантай, Ариун Сүнсний нэгдэлтэй,"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "үүрд мөнх оршин хаанчилдаг цорын ганц"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурхан билээ."
          }
        ]
      }
    ],
    "page": 646,
    "source": {
      "kind": "seasonal",
      "season": "LENT",
      "weekKey": "1",
      "dayKey": "FRI",
      "hour": "vespers"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн Есүс Өөрийн хүмүүсийг цусаараа ариусгав. Бүгдээрээ Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Өөрийн хүмүүсээ өршөөнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хайрт Аврагч минь, Та тарчлалтаараа дамжуулан бидэнд өөрийгөө үгүйсгэхийг зааж өгөн, хорон муугийн эсрэг болон гай зовлонгийн үед биднийг хүчтэй болгож, итгэл найдварыг минь өөгшүүлж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн биднийг Таны амилалтыг тэмдэглэхэд бэлэн болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны эш үзүүлэгчид болсон сүсэгтнүүдийг Христ Таныг газар болгонд мэдүүлэхэд туслан соёрхоно уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн тэд амьд итгэл, найдвар болон хайраар Таны тухай гэрчлэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийн хүч чадлыг бүх зовж шаналагчдад соёрхож өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн өөрсдийн хайр халамжаар тэднийг сэргээхэд бидэнд тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Сүсэгтнүүд зовох үедээ Таны тарчлалтыг мэдрэхэд Та тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн авралынхаа хүчийг бусдад үзүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Амьдралыг бүтээгч минь, энэ ертөнцөөс хальж одсон хүмүүсийг Та эргэн санана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэдэнтэй Та амилалтын амьдралын сүр жавхланг хуваалцана уу."
              }
            ]
          }
        ]
      }
    ],
