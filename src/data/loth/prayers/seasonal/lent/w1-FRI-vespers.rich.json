  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн Есүс Өөрийн хүмүүсийг цусаараа ариусгав. Бүгдээрээ Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Өөрийн хүмүүсээ өршөөнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хайрт Аврагч минь, Та тарчлалтаараа дамжуулан бидэнд өөрийгөө үгүйсгэхийг зааж өгөн, хорон муугийн эсрэг болон гай зовлонгийн үед биднийг хүчтэй болгож, итгэл найдварыг минь өөгшүүлж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн биднийг Таны амилалтыг тэмдэглэхэд бэлэн болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны эш үзүүлэгчид болсон сүсэгтнүүдийг Христ Таныг газар болгонд мэдүүлэхэд туслан соёрхоно уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн тэд амьд итгэл, найдвар болон хайраар Таны тухай гэрчлэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийн хүч чадлыг бүх зовж шаналагчдад соёрхож өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн өөрсдийн хайр халамжаар тэднийг сэргээхэд бидэнд тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Сүсэгтнүүд зовох үедээ Таны тарчлалтыг мэдрэхэд Та тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн авралынхаа хүчийг бусдад үзүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Амьдралыг бүтээгч минь, энэ ертөнцөөс хальж одсон хүмүүсийг Та эргэн санана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэдэнтэй Та амилалтын амьдралын сүр жавхланг хуваалцана уу."
              }
            ]
          }
        ]
      }
    ],
