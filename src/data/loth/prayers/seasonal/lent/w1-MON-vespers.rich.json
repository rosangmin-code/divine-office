    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Есүс Христ бидний Эзэн биднийг гэм нүглээс нь аварсан. Түүний ард түмний хувьд Түүнд хандан залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Давидын Хүү Есүс ээ, биднийг өршөөнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Христ Эзэн, бид Таны ариун Шашны төлөө залбирч байна. Та үүнийг ариун болгохоор Өөрийгөө өргөн барьсан бөгөөд усаар болон амийг тэтгэгч үгээр ариусгасан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та үүнийг наманчлалаар нь ариусгаж, байнга шинэчилж байна уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Сайн багш минь, Та залуучуудад тэдний хүн нэг бүрийн төлөө сонгосон замыг нь харуулна уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр тэд Таны замаар алхаж, үүргээ биелүүлэх болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та нигүүлсэнгүй сэтгэлээр бүх төрлийн өвчнийг эдгээдэг тул өвчтэй хүмүүст итгэл найдварыг хайрлаж, тэднийг дахин босоход нь тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидэнд тэднийг хайрлаж, халамжлахыг зааж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Усан угаалаар олгосон эрхэм чанарыг бидэнд ухааруулна уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Цаг хором мөч бүр бид Таны төлөө амьдрах болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Талийгаачид Таны амар амгалан дотор цог жавхлангаар амилах болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг тэдэнтэй хамт Өөрийн хаанчлалд оруулна уу."
              }
            ]
          }
        ]
      }
    ],
