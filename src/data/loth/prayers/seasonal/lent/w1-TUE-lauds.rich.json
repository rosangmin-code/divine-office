        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "versicle",
            "text": "Тэр намайг худал яриагаар залилан мэхлэх гэж буй хүмүүсээс,"
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "response",
            "text": "Мөн анчны урхинаас чөлөөлөх болно."
