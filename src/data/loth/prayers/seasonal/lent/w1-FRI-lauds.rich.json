  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Загалмай дээрх Өөрийн үхлээр бидэнд амьдралыг авчирсан Эзэн Есүс Христэд талархал нь байх болтугай. Хамаг зүрх сэтгэлээсээ Түүнээс гуйн ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Та үхлээрээ биднийг амьдруулна уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Аврагч ба Багш минь, Та чин үнэнч байдлаа бидэнд харуулсан бөгөөд мөн Та тарчлалаараа биднийг шинэ бүтээл болгосон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг дахин гэм нүгэлд унахаас сэргийлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Өнөөдөр биднийг өөрсдийгөө умартахад тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Харин тусламж шаардагдсан хүмүүсийг үл умартахад тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бид энэхүү гэмшлийн өдрийг Таны хишигтэй адил хүлээн авах болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн өршөөл нигүүлслийн үйлсээрээ дамжуулан Танд буцаан өгөх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хатуу зүрх сэтгэлтэй удирдагч минь, Та бидний тэрслэгч зүрхийг ноёрхож,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өгөөмөр занг зааж өгнө үү."
              }
            ]
          }
        ]
      }
