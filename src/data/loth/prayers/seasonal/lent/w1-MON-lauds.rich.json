    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Үхлээрээ дамжуулан бидний төлөө авралын замыг нээж өгсөн Аврагч Есүсээ магтацгаая. Бүгдээрээ Түүнд хандан ийн гуйн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Та ард түмнээ Өөрийн замаар явахад удирдаж өгнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Өршөөл нигүүлслийн Тэнгэрбурхан минь, Та усан угаалаар дамжуулан бидэнд шинэ амьдралыг өгсөн билээ."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тантай адил биднийг өдөр өдрөөр өсөхөд тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бидний өгөөмөр сэтгэл өнөөдөр хэрэгцээ шаардлагатай хүмүүст нь баяр баясгаланг авчрах болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн тэдэнд тусалснаар бид Таныг олох болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны мэлмийн өмнө юу сайн, юу зөв, юу үнэнийг бидэнд хийхэд тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн Таныг хоёргүй сэтгэлээр үргэлж эрэлхийлэхэд тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Гэр бүлийнхээ нэгдлийн эсрэг хийсэн гэм нүглийг минь өршөөнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг нэг л зүрхтэй, нэг л сүнстэй болгоно уу."
              }
            ]
          }
        ]
      }
    ],
