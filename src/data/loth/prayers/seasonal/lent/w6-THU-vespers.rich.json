{
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Сүүлчийн оройн зоогийн үед баригдсан тэр шөнөө бидний Аврагч Өөрийн үхэл болон амилалтын дурсгалыг үүрд мөнхөд ёслон тэмдэглэхээр Шашиндаа даатгасан билээ. Түүнийг шүтэн биширч, Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Цусаараа цагаатгагдсан хүмүүсээ Та ариусгана уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Дэлхийг Цагаатгагч минь, Та биднийг гэмших сэтгэлээр дамжуулан Өөрийн тарчлалтыг ихэд мэдрүүлнэ үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид Таны амилалтын сүр жавхланг хуваалцах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Зовж шаналагчдыг тайтгаруулагч Таны Эх биднийг хамгаалах болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та биднийг тайтгаруулдаг лугаа адил бид бусдыг тайтгаруулдаг байх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Сүсэгтнүүд тань зовох үедээ Таны тарчлалтыг хуваалцахад тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн авралынхаа ид хүчийг тэдний амьдралд илчилж үзүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та үхлийг болон загалмай дээрх үхлийг хүлээн зөвшөөрөх хүртлээ дуулгавартай байснаар Өөрийгөө хоосолсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Дуулгавартай байдал болон тэвчээрийн хишгүүдийг Танд үйлчилдэг бүх хүнд өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та талийгаач бологсдын биеийг сүр жавхлант биетэйгээ адил болгон хувиргана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн сүүлийн өдөр биднийг тэдний нөхөрлөлд аваачна уу."
              }
            ]
          }
        ]
      }
    ],
    "page": 660,
    "source": {
      "kind": "seasonal",
      "season": "LENT",
      "weekKey": "6",
      "dayKey": "THU",
      "hour": "vespers"
    }
  },
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эцэг минь, Та Өөрийн сүр жавхлангийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "төлөө болон бидний авралын төлөө Есүс Христийг"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "мөнхийн Тэргүүн Тайлгачаар өргөмжилсөн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "билээ. Түүний цусаар Таны эрхшээлд оруулсан"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "ард түмэн Эвхаристын ёслолын үед Түүний"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "дурсгалыг тэмдэглэснээрээ Түүний загалмай"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "болон амилалтын ид хүчийг хуваалцах болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тэрээр Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг цорын ганц Тэнгэрбурхан билээ."
          }
        ]
      }
    ],
    "page": 663,
    "source": {
