{
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн Христ бидэнд бие биеэ хайрла гэсэн шинэ тушаал өгсөн тул Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Өөрийн ард түмнээ энэрэл хайраар бүтээнэ үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Сайн багш аа, хөршөө хайрласнаараа Таныг хайрлахыг,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн тэдэнд үйлчилснээрээ Танд үйлчилж болохыг бидэнд зааж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та загалмай дээр алуурчдынхаа төлөө уучлалт гуйсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Дайснуудаа хайрлах ба биднийг хавчигчдын төлөө залбирах хүчийг Та бидэнд соёрхоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та Өөрийнхөө бие болон цусны далд нууцаар дамжуулан бидний хайр, тэвчээр болон итгэлийг гүнзгийрүүлж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн сул доройг хүчирхэгжүүлж, зовж буй хүмүүсийг тайтгаруулж, амь тэмцэж буй хүмүүст горьдол найдварыг өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Дэлхийн гэрэл минь, Та төрөлхийн сохор хүнийг Силоамын усанд угаан хараа оруулсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Шашныхаа сонсогч нарыг усан угаалын усаар болон амьдралын үгээр дамжуулан гэгээрүүлнэ үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Талийгаач бологсдод Та Өөрийн мөнхийн хайраар төгс баяр баяслыг соёрхоно уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Мөн биднийг Өөрийн сонгосон хүмүүсийн дунд хүлээн авна уу."
              }
            ]
          }
        ]
      }
    ],
    "page": 643,
