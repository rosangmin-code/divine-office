{
  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эцэг минь, дөчин хоногийн цаг улирлын сахилгаар уламжлан Таны Хүүгийн үхэл болон амилалтыг бидэнд ойлгоход болон үүнийг амьдралаараа тусгахад тусална уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 620,
    "source": {
      "kind": "seasonal",
      "season": "LENT",
      "weekKey": "1",
      "dayKey": "SUN",
      "hour": "lauds"
    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Энэхүү хишиг ивээлийн цаг улирлыг бидний төлөө олж авсан Аврагч Эзэнээ магтан дуулж, Түүнд хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэн минь, Та бидний дотор шинэ сүнсийг өгнө үү."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Христ минь, амьдрал минь, ариун угаалаар уламжлан бид Тантай хамт оршуулагдаж, шинэ амьдралд амилуулагдсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өнөөдөр бид шинэ амьдралаар алхах болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Эзэн, бүх хүн төрөлхтөнд Та адислалыг авчирсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бүгдийн сайн сайхны төлөө санаа тавьж байгаагаа Та бидэнтэй мөн хуваалцана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Үргэлж байдаг мөнхийн хотыг ширтэсэн нүдтэй бид"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Дэлхийн хот байгуулахаар бие биетэйгээ хамтран ажиллах болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бие ба сэтгэлийг илааршуулагч минь, Та бидний сүнсний өвчнийг илаарьшуулна уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр Таны байнгын анхаарал халамжаар бид ариун байдал дотор өсөж хөгжиж болох юм."
              }
            ]
          }
        ]
      }
    ],
