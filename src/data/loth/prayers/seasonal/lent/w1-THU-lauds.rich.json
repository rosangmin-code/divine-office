{
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христ бидний Эзэн биднийг үхлийн харанхуйд биш, харин Өөрийнхөө гэрэлд алхуулахын тулд дэлхий ертөнцийн гэрэл болж бидний дунд ирсэн билээ. Түүнийг алдаршуулан Түүнд ийн хандан залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Таны үг биднийг удирдах дэнлүү болох болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Нигүүлсэнгүй Тэнгэрбурхан минь, өнөөдөр биднийг Тантай илүү адил аж төрөхөд тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр Адам дотор нүгэл үйлдсэн бид Христ дотор амилах болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны үг биднийг удирдагч дэнлүү болох болтугай."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр бид Таны үнэн дотор амьдарч, Таны энэрэл хайраар цаг ямагт өсөж хүмүүжих болно."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таны төлөө нийтийн сайн сайхныг эрэлхийлэхдээ үнэнч байхыг Та бидэнд зааж өгнө үү."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ингэснээр Таны гэрэл Таны Шашнаар дамжуулан бүх хүн төрөлхтний гэр бүлийг гэрэлтэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та биднийг Өөртөө нөхөрлөх нөхөрлөлийг илүү ихээр хайлгаж,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өөрийн мэргэн ухаан, сайн сайхны эсрэг үйлдсэн бидний гэм нүглийг наманчлуулахын тулд бидний зүрх сэтгэлийг хөндөн хөдөлгөнө үү."
              }
            ]
          }
        ]
      }
    ],
    "page": 640,
    "source": {
