  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Христийг Йерусалим руу ороход Түүнийг Хаан болон Мессиа хэмээн хүлээн авсан. Бүгдээрээ Түүнийг шүтэн биширч, баясалтайгаар ийн магтан дуулцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эзэний нэр алдраар ирэгч нь ерөөлтэй еэ!"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бүх үеийнхний Хаан, Давидын Хүүд Хосанна."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Харанхуйн эрх мэдлүүд болон үхлийг ялан дийлэгчид Хосанна."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та зовлонг эдлэхээр Йерусалим руу явсан бөгөөд үүгээрээ Өөрийн сүр жавхлант байдалд орсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та Өөрийн Шашныг тэнгэр дэх Дээгүүр өнгөрөх зоог руу удирдаж өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та загалмайгаа амийн мод болгосон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ариун угаалаар дахин төрөгсдөд энэхүү модны үр жимсийг өгнө үү."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Хүн төрөлхтний аврагч минь, Та гэм нүгэлтнүүдийг аврахаар ирсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Итгэл, найдвар, хайрыг баримталж буй бүх хүнийг Өөрийн хаанчлалд аваачна уу."
              }
            ]
          }
        ]
      }
