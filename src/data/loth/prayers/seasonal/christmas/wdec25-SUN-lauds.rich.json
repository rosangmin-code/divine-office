    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Дэлхий ертөнцийг бүтээхээс өмнө Тэнгэрбурханы Үг оршдог байсан бөгөөд цаг нь болоход бидний дунд мэндэлсэн билээ. Түүнийг магтан алдаршуулахдаа баяр хөөртэйгөөр залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Та ирсэн болохоор газар дэлхий баяртайгаар хашхирах болтугай."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бол мэндлэхдээ баяр баясгалангаар дэлхийг бялхаасан Тэнгэрбурханы мөнхийн Үг мөний тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та амьдралынхаа байнгын билигт хишгээр дамжуулан биднийг баяр хөөрөөр бялхаана уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та мэндэлснээрээ Эзэний үнэнч эвслийн гэрээг бидэнд илчилсэн төдийгүй мөн биднийг аварсан тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг Ариун угаалынхаа амлалтад үнэнч байхад тусална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бол бүх хүмүүст амар амгаланг тунхаглах тэнгэрэлчүүдийг илгээсэн тэнгэр ба газрын Хаан мөний тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Бидний амьдрал Таны амар амгалангаар дүүрэн байх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та бол амьдралын үр жимсийг ургуулдаг жинхэнэ усан үзмийн мод мөний тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та биднийг үр жимсээ их өгдөг усан үзмийн модны мөчрүүд болгоно уу."
              }
            ]
          }
        ]
      }
    ],
