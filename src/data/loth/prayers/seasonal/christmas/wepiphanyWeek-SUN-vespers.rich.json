  "concludingPrayerRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Аяа, Эцэг минь, өнөөдөр Та Амин Ганц Хүүгээ одын удирдлагаар үндэстнүүдэд илчилсэн тул итгэл бишрэлийн гэгээн гэрлээр дамжуулан"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "биднийг тэнгэрийн орон дахь Өөрийн сүр жавхлан өөд удирдан зална уу. Тантай, Ариун Сүнсний нэгдэлтэй, үүрд мөнх оршин хаанчилдаг Тэнгэрбурхан Есүс Христ бидний Эзэн, Таны Хүүгээр уламжлан тийн болтугай."
          }
        ]
      }
    ],
    "page": 609,
    "source": {
      "kind": "seasonal",
      "season": "CHRISTMAS",
      "weekKey": "epiphanyWeek",
      "dayKey": "SUN",
      "hour": "vespers"
    }
  },
