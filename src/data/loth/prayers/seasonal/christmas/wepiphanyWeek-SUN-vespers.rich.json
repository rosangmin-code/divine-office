        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "ойрхон байгаа тул биднийг манай энэ ертөнцийн"
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "хязгаараас чөлөөлж, Таны Ариун Сүнс бүх"
