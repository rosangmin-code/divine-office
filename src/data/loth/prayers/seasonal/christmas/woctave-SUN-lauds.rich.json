  "shortReadingRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Бидний төлөө Хөвгүүн төрж, Бидэнд Хүү өгөгдсөн аж. Засаглал Түүний мөрөн дээр байж, Түүний нэрийг “Гайхамшигт Зөвлөгч, Хүчит Тэнгэрбурхан, Мөнхийн Эцэг, Энхийн Жонон” гэж дуудна. Давидын сэнтий дээр, Түүний хаанчлал дээгүүр Түүний засаглал хийгээд амар тайван нь эцэсгүй тэлнэ. Шударга ёс, үнэн зөвөөр үүнийг өдгөөгөөс өнө мөнхөд тогтооно. Түг түмдийн ЭЗЭНий зүтгэл Түүнийг нь гүйцэлдүүлэх болно."
          }
        ]
      }
    ],
