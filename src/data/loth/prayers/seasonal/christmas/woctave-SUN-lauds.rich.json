{
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Эцэг юм бүхнийг Христ дотор шинээр бий болгохоор таалсан тул Түүндээ хандан ийн залбирцгаая:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Тэнгэрбурханы хайрт Хүү, Та биднийг сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурханы хайрт Хүү Та эхэн цагт Эцэгтэйгээ хамт байсан бөгөөд цаг нь болоход хүн болсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Хамаг хүмүүсийг хайрлах ахан дүүсийн хайрыг бидэнд соёрхоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Биднийг баян болгохоор Та ядуу болсон билээ. Түүнчлэн Өөрийн сул дорой байдлаар биднийг өргөмжлөх хийгээд Өөрийн сүр жавхланг хуваалцагчид болгохоор Та Өөрийгөө хоосолсон тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Биднийг Өөрийн сайнмэдээний айлдлыг үнэнч тунхаглагчид болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Та харанхуй хийгээд үхлийн сүүдэрт суугсдын дээр гийдэг тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Ариун гэгэн байдал, шударга ёс ба амар амгаланг бидэнд соёрхоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Бидэнд зөв шударга, үнэнч зүрхийг соёрхоно уу. Ингэснээр бид Таны үгийг сонсох болно."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Өөрийн суу алдрын төлөө Та Өөрийн үгийг бидний дотор болон энэ дэлхий дээр төгс төгөлдөр болгоно уу."
              }
            ]
          }
        ]
      }
    ],
