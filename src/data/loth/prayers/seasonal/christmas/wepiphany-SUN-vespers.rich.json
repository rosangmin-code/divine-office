    }
  },
  "intercessionsRich": {
    "blocks": [
      {
        "kind": "para",
        "spans": [
          {
            "kind": "text",
            "text": "Залбирал, магтаалаар бүх Христэд итгэгчидтэй нэгдсэн бид Эзэнээс ийн гуйж байна:"
          }
        ]
      },
      {
        "kind": "para",
        "indent": 1,
        "spans": [
          {
            "kind": "text",
            "text": "Эцэг минь, Өөрийн хүүхдүүдээ сонсоно уу."
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрбурханыг мэддэггүй хэрнээ оюун санааныхаа төсөөлөл болон зөн совиндоо Тэнгэрбурханыг эрж хайж байгаа тэдгээр хүмүүст Та тусална уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Та тэднийг Христийн гэрлийн дотор шинэ хүмүүс болгоно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Таныг жинхэнэ Тэнгэрбурхан гэж итгэдэг, эцсийн өдөр шүүх дээр Таныг ирэхийг хүлээж буй бүх хүмүүсийг Та ивээлдээ багтаана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэдний төлөө гэсэн Таны үүрдийн хайрыг тэд мэдэх болтугай."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Амьдрал, гэрэл болон бүх сайн зүйлсийг соёрхсон бүх хүмүүсээ Та дурсан санана уу."
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэднийг оршихуйгаасаа хэзээ ч бүү холдооно уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Тэнгэрэлчийн ивээлээр дамжуулан Та бүх аялагчдыг сахиж,"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Гэнэтийн болон зуурдын үхлээс хамгаална уу."
              }
            ]
          }
        ]
      },
      {
        "kind": "divider"
      },
      {
        "kind": "stanza",
        "lines": [
          {
            "indent": 0,
            "spans": [
              {
                "kind": "text",
                "text": "Дэлхий дээр амьдарч байхдаа одоогийн нас барагсдад Та үнэнийг илчилсэн тул"
              }
            ]
          },
          {
            "indent": 1,
            "spans": [
              {
                "kind": "rubric",
                "text": "- "
              },
              {
                "kind": "text",
                "text": "Тэднийг Таны дүр төрхийн гоо сайхныг тунгаан бодоход удирдаж өгнө үү."
              }
            ]
          }
        ]
      }
    ],
