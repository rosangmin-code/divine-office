      {
        "kind": "para",
        "spans": [
          {
            "kind": "versicle",
            "text": "Тэр дэлхийн гэм нүглийн төлөө нас барж, Ариун Сүнсний хүчээр амилсан."
          }
        ]
      },
      {
        "kind": "para",
        "spans": [
          {
            "kind": "response",
            "text": "Биднийг Тэнгэрбурханд өргөл болгохын тулд юм."
