          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Гэм нүглийн харанхуйгаас салсан хэнбугай ч"
                }
              ],
              "indent": 0
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Тэнгэрбурханыг хүсэн тэмүүлнэ."
                }
              ],
              "indent": 0
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Тэнгэрбурхан, Та миний Тэнгэрбурхан"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Би Таныг эртлэн хайх болой."
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Усгүй, хуурай, ангамал газарт"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Сэтгэл минь Танаар цангаж,"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Бие махбод минь Таныг"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Хүсэн тэмүүлж байна."
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Таныг би ариун газарт хайсан."
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Таны хүч, Таны алдрыг харсан."
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Учир нь хайр энэрэл тань"
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Амь амьдралаас илүү."
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Уруул минь Таныг магтана."
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Ийнхүү би амьддаа Таныг магтана."
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Таны нэрээр би гараа өргөх болно."
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Чөмөг, өөхөнд юм шиг"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Сэтгэл минь цатгалан бөгөөд"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Ам минь баясгалант уруулаар магтаалуудыг"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "өргөнө."
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Шөнөжин Таны тухай тунгаан бодохдоо"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Орондоо Таныг би дурсан санана,"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Учир нь Та миний тусламж бөгөөд"
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Таны жигүүрийн дор"
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Би баясгалантайгаар дуулна."
                }
              ],
              "indent": 1
            }
          ]
        },
        {
          "kind": "stanza",
          "lines": [
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Сэтгэл минь Танаас зуурчээ."
                }
              ],
              "indent": 1
            },
            {
              "spans": [
                {
                  "kind": "text",
                  "text": "Таны баруун мутар намайг түшиж байна."
                }
              ],
              "indent": 1
            }
          ]
        }
      ]
    }
